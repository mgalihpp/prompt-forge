generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId     String // owner (Clerk user id)
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clerkId])
}

model ChatThread {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String // owner (Clerk user id)
  title     String // derived from the first user message
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([clerkId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String     @db.ObjectId
  clerkId   String // denormalized owner — search/delete filter without a join
  role      String // "user" | "assistant"
  text      String
  parts     Json? // structured UIMessage parts (deep-forge variants); null for plain turns
  createdAt DateTime   @default(now())
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([clerkId])
}

model ForgedPrompt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String // owner (Clerk user id)
  title     String // short label, derived from the ore
  ore       String // the user's raw input
  blade     String // the forged prompt
  opts      Json // the knob values used (mode/persona/tone/format/target)
  deepForge Boolean  @default(false)
  favorite  Boolean  @default(false)
  shareId   String?  @unique // set when publicly shared
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model DailyUsage {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  clerkId String
  day     String // UTC calendar day, "YYYY-MM-DD" — reset is implicit via the key
  count   Int    @default(0)

  @@unique([clerkId, day])
}
